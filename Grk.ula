CreateBattleBtn.TextSize = 10
Instance.new("UICorner", CreateBattleBtn).CornerRadius = UDim.new(0, 4)

CreateBattleBtn.MouseButton1Click:Connect(function()
    local caseName = CaseDropdown.Text
    local amount = tonumber(BattleCountBox.Text) or 10
    if amount < 1 then amount = 1 elseif amount > 10 then amount = 10 end
    local cases = {}
    for i = 1, amount do table.insert(cases, caseName) end
    local Battles = Events:FindFirstChild("Battles")
    if Battles then
        pcall(function() Battles:InvokeServer("Create", cases, {}) end)
        task.wait(0.5)
        pcall(function() Battles:InvokeServer("CallABot") end)
    end
end)

