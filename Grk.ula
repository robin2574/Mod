    ["Trash"] = 0, ["Daily"] = 0, ["Beggar"] = 220, ["Plodder"] = 444,
    ["Office Clerk"] = 689, ["Manager"] = 835, ["Director"] = 926,
    ["Oligarch"] = 1364, ["Gold"] = 1999, ["Frozen Heart"] = 4500,
    ["Dark"] = 4999, ["Bubble Gum"] = 12000, ["Palm"] = 13999,
    ["Burj"] = 37999, ["Cats"] = 40000, ["M5 F90"] = 55555,
    ["Luxury"] = 119999, ["Glitch"] = 135000, ["G63"] = 177777,
    ["Dream"] = 250000, ["Porsche 911"] = 599999, ["URUS"] = 1666666,
