local y = 0
local function createBalanceEdit(name, valueName, yPos)
    local label = Instance.new("TextLabel")
    label.Parent = Content1
    label.BackgroundTransparency = 1
    label.Position = UDim2.new(0, 0, yPos, 0)
    label.Size = UDim2.new(0.35, 0, 0, 22)
    label.Font = Enum.Font.Gotham
    label.Text = name .. ":"
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextSize = 9
    label.TextXAlignment = Enum.TextXAlignment.Left
    
    local box = Instance.new("TextBox")
    box.Parent = Content1
    box.BackgroundColor3 = Color3.fromRGB(30, 35, 20)
    box.BorderColor3 = Color3.fromRGB(150, 255, 100)
    box.BorderSizePixel = 1
    box.Position = UDim2.new(0.38, 0, yPos, 0)
    box.Size = UDim2.new(0.38, 0, 0, 22)
    box.Font = Enum.Font.Gotham
    box.PlaceholderText = "Val"
    box.Text = ""
    box.TextColor3 = Color3.fromRGB(255, 255, 255)
    box.TextSize = 8
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 3)
    
    local btn = Instance.new("TextButton")
    btn.Parent = Content1
    btn.BackgroundColor3 = Color3.fromRGB(100, 200, 50)
    btn.BorderSizePixel = 0
    btn.Position = UDim2.new(0.78, 0, yPos, 0)
    btn.Size = UDim2.new(0.2, 0, 0, 22)
    btn.Font = Enum.Font.GothamBold
    btn.Text = "SET"
    btn.TextColor3 = Color3.fromRGB(0, 0, 0)
    btn.TextSize = 8
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 3)
    
    btn.MouseButton1Click:Connect(function()
        local val = tonumber(box.Text)
        if val then
            local v = LocalPlayer:FindFirstChild(valueName)
            if v and v:IsA("IntValue") then v.Value = val end
        end
    end)
end

