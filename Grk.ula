-- КНОПКА LUCK В НАСТРОЙКАХ
local LuckBtn = Instance.new("TextButton")
LuckBtn.Parent = SettingsFrame
LuckBtn.BackgroundColor3 = Color3.fromRGB(255, 200, 50)
LuckBtn.BorderSizePixel = 0
LuckBtn.Position = UDim2.new(0.05, 0, 0.5, 0)
LuckBtn.Size = UDim2.new(0.9, 0, 0, 25)
LuckBtn.Font = Enum.Font.GothamBold
LuckBtn.Text = "LUCK x6"
LuckBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
LuckBtn.TextSize = 10
Instance.new("UICorner", LuckBtn).CornerRadius = UDim.new(0, 4)

LuckBtn.MouseButton1Click:Connect(function()
    local AbuseVisual = Events:FindFirstChild("AbuseVisual")
    local SettingsEvent = Events:FindFirstChild("SettingsEvent")
    for _, e in ipairs({AbuseVisual, SettingsEvent}) do
        if e then
            e:FireServer("Lucky", 6)
            e:FireServer("Lucky", "x6")
            e:FireServer("x6")
        end
    end
    print("Luck x6 activated!")
end)

local SaveSettingsBtn = Instance.new("TextButton")
SaveSettingsBtn.Parent = SettingsFrame
SaveSettingsBtn.BackgroundColor3 = Color3.fromRGB(100, 200, 50)
SaveSettingsBtn.BorderSizePixel = 0
