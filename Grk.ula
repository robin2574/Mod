local y2 = 0

for i, mult in ipairs({2, 4, 6}) do
    local btn = Instance.new("TextButton")
    btn.Parent = Content2
    btn.BackgroundColor3 = Color3.fromRGB(255, 150 + (i-1)*30, 50)
    btn.BorderSizePixel = 0
    btn.Position = UDim2.new((i-1)*0.33, 0, y2, 0)
