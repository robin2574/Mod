AddInvBtn.MouseButton1Click:Connect(function()
    local name = InvDropdown.Text
    local count = tonumber(InvCountBox.Text) or 1
    if name ~= "Select NFT" and name ~= "" then
        -- Inventory
        local inv = LocalPlayer:FindFirstChild("_Inventory") or Instance.new("Folder", LocalPlayer)
        inv.Name = "_Inventory"
        for i = 1, count do
            local item = Instance.new("StringValue", inv)
            item.Name = name
            item.Value = name
        end
        -- Index
        local idx = LocalPlayer:FindFirstChild("_Index") or Instance.new("Folder", LocalPlayer)
        idx.Name = "_Index"
        local item = idx:FindFirstChild(name)
        if not item then
            item = Instance.new("IntValue", idx)
            item.Name = name
        end
        item.Value = (item.Value or 0) + count
    end
end)

