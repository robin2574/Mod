    btn.TextSize = 11
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
    btn.MouseButton1Click:Connect(function()
        local AbuseVisual = Events:FindFirstChild("AbuseVisual")
        local SettingsEvent = Events:FindFirstChild("SettingsEvent")
        for _, e in ipairs({AbuseVisual, SettingsEvent}) do
            if e then
                e:FireServer("Lucky", mult)
                e:FireServer("Lucky", "x" .. mult)
                e:FireServer("x" .. mult)
            end
        end
    end)
end

