}

local CustomCases = {}
for i, v in ipairs(Cases) do table.insert(CustomCases, v) end
local SelectedCases = {"Heavenfall"}

local function getAvatar(userId)
    return "https://www.roblox.com/headshot-thumbnail/image?userId=" .. userId .. "&width=100&height=100&format=png"
end

