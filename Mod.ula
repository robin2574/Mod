-- Выпадающий список кейсов
local CaseList = Instance.new("ScrollingFrame")
CaseList.Parent = BattlesFrame
CaseList.BackgroundColor3 = Color3.fromRGB(25, 30, 15)
CaseList.BorderColor3 = Color3.fromRGB(255, 100, 50)
CaseList.BorderSizePixel = 1
CaseList.Position = UDim2.new(0.05, 0, 0.3, 0)
CaseList.Size = UDim2.new(0.9, 0, 0, 150)
CaseList.Visible = false
CaseList.ScrollBarThickness = 4
Instance.new("UICorner", CaseList).CornerRadius = UDim.new(0, 5)

local CaseListLayout = Instance.new("UIListLayout")
CaseListLayout.Parent = CaseList
CaseListLayout.Padding = UDim.new(0, 2)

for i, caseName in ipairs(Cases) do
    if CasePrices[caseName] and CasePrices[caseName] >= 100 then
        local btn = Instance.new("TextButton")
        btn.Parent = CaseList
        btn.BackgroundColor3 = Color3.fromRGB(35, 40, 25)
        btn.BorderSizePixel = 0
        btn.Size = UDim2.new(1, 0, 0, 30)
        btn.Font = Enum.Font.Gotham
        btn.Text = caseName .. " (" .. CasePrices[caseName] .. ")"
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextSize = 10
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
        
        btn.MouseButton1Click:Connect(function()
            CaseDropdown.Text = caseName
            CaseList.Visible = false
        end)
    end
end
