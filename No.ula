local bf=Instance.new("Frame",P2);bf.Size=UDim2.new(1,0,0,18);bf.Position=UDim2.new(0,0,0,y2);bf.BackgroundColor3=Color3.fromRGB(30,30,30)
local bi=Instance.new("TextBox",bf);bi.Text="1";bi.Size=UDim2.new(0,25,1,-2);bi.Position=UDim2.new(0,2,0,1);bi.BackgroundColor3=Color3.fromRGB(50,50,50);bi.TextColor3=Color3.new(1,1,1);bi.Font=Enum.Font.Gotham;bi.TextSize=8;bi.FocusLost:Connect(function()BattleCount=tonumber(bi.Text)or 1;bi.Text=tostring(BattleCount)end)
y2=y2+22
local bb=Instance.new("TextButton",P2);bb.Text="▶ АВТО БАТЛЫ";bb.Size=UDim2.new(1,0,0,22);bb.Position=UDim2.new(0,0,0,y2);bb.BackgroundColor3=Color3.fromRGB(255,120,0);bb.TextColor3=Color3.new(1,1,1);bb.Font=Enum.Font.GothamBold;bb.TextSize=9
bb.MouseButton1Click:Connect(function()
 BattleOn=not BattleOn;bb.Text=BattleOn and"■ СТОП"or"▶ АВТО БАТЛЫ";bb.BackgroundColor3=BattleOn and Color3.fromRGB(255,30,30)or Color3.fromRGB(255,120,0)
 if BattleOn then task.spawn(function()while BattleOn do local bc={};for cn,_ in pairs(BattleCases)do for i=1,BattleCount do table.insert(bc,cn);if #bc>=10 then break end end;if #bc>=10 then break end end;if #bc>0 then pcall(function()Events.Battles:InvokeServer("Create",bc,{})end)end;task.wait(30)end end)end
end)

local ly=0
local function AB(tx,cb)local b=Instance.new("TextButton",P3);b.Text=tx;b.Size=UDim2.new(1,0,0,18);b.Position=UDim2.new(0,0,0,ly);b.BackgroundColor3=Theme;b.TextColor3=Color3.new(1,1,1);b.Font=Enum.Font.Gotham;b.TextSize=7;b.MouseButton1Click:Connect(cb);ly=ly+19 end
local function AI(tx,cb)local f=Instance.new("Frame",P3);f.Size=UDim2.new(1,0,0,18);f.Position=UDim2.new(0,0,0,ly);f.BackgroundColor3=Color3.fromRGB(35,35,35)
local i=Instance.new("TextBox",f);i.PlaceholderText=tx;i.Size=UDim2.new(.7,0,1,0);i.BackgroundColor3=Color3.fromRGB(50,50,50);i.TextColor3=Color3.new(1,1,1);i.Font=Enum.Font.Gotham;i.TextSize=7
local o=Instance.new("TextButton",f);o.Text="OK";o.Size=UDim2.new(.3,0,1,0);o.Position=UDim2.new(.7,0,0,0);o.BackgroundColor3=Theme;o.TextColor3=Color3.new(1,1,1);o.Font=Enum.Font.GothamBold;o.TextSize=7;o.MouseButton1Click:Connect(function()cb(i.Text)i.Text=""end);ly=ly+19 end
AB("💰 Вся валюта",function()for _,n in ipairs({"_StarsValue","_TONValue","_GemsValue","_SnowflakesValue"})do local v=Player:FindFirstChild(n);if v then v.Value=999999999 end end end)
AB("⚡ Fast Upgrade",function()local p=Player:FindFirstChild("_1628441770")or Instance.new("NumberValue",Player);p.Name="_1628441770";p.Value=1 end)
AB("📊 Заполнить индекс",function()local idx=Player:FindFirstChild("_Index");if idx then for _,v in ipairs(idx:GetChildren())do if v:IsA("IntValue")then v.Value=999999 end end end end)
AI("NFT в инвентарь",function(t)Instance.new("StringValue",Player._Inventory).Name=t end)
AI("Лучший дроп",function(t)local d=Player:FindFirstChild("_BestDrop");if d then d.Value=t end end)
AI("NFT в индекс (имя,кол)",function(t)local parts=t:split(",");local idx=Player:FindFirstChild("_Index");if idx then local v=idx:FindFirstChild(parts[1]);if not v then v=Instance.new("IntValue",idx);v.Name=parts[1]end;v.Value=v.Value+(tonumber(parts[2])or 1)end end)
AB("🍀 Удача x2 10мин",function()local l=RS:FindFirstChild("LuckValue");if l then l.Value=600 end;local lp=Player:FindFirstChild("_LuckyPotion");if lp then lp.Value=600 end end)
AB("🍀 Удача x4 10мин",function()local l=RS:FindFirstChild("LuckValue2");if l then l.Value=600 end;local lp=Player:FindFirstChild("_LuckyPotion2");if lp then lp.Value=600 end end)
AB("✝️ Благословение 5мин",function()local c=RS:FindFirstChild("CrossValue");if c then c.Value=300 end end)
P3.CanvasSize=UDim2.new(0,0,0,ly+10)

