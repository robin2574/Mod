local ci=Instance.new("TextBox",cf);ci.Text="1";ci.Size=UDim2.new(0,25,1,-2);ci.Position=UDim2.new(0,2,0,1);ci.BackgroundColor3=Color3.fromRGB(50,50,50);ci.TextColor3=Color3.new(1,1,1);ci.Font=Enum.Font.Gotham;ci.TextSize=8;ci.FocusLost:Connect(function()Count=tonumber(ci.Text)or 1;ci.Text=tostring(Count)end)
local cl=Instance.new("TextLabel",cf);cl.Text="шт/раз";cl.Size=UDim2.new(1,-30,1,0);cl.Position=UDim2.new(0,28,0,0);cl.TextColor3=Color3.new(.7,.7,.7);cl.Font=Enum.Font.Gotham;cl.TextSize=7;cl.BackgroundTransparency=1;cl.TextXAlignment=Enum.TextXAlignment.Left
y=y+20

local as=Instance.new("TextButton",P1);as.Text="Авто продажа: ВЫКЛ";as.Size=UDim2.new(1,0,0,16);as.Position=UDim2.new(0,0,0,y);as.BackgroundColor3=Color3.fromRGB(50,50,50);as.TextColor3=Color3.new(1,1,1);as.Font=Enum.Font.Gotham;as.TextSize=7
as.MouseButton1Click:Connect(function()AutoSell=not AutoSell;as.Text="Авто продажа: "..(AutoSell and"ВКЛ"or"ВЫКЛ");as.BackgroundColor3=AutoSell and Color3.fromRGB(0,150,0)or Color3.fromRGB(50,50,50)end)
