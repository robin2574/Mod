-- NFT Battle v6.5 Full
local Player=game.Players.LocalPlayer
local RS=game:GetService("ReplicatedStorage")
local Events=RS.Events
local PG=Player.PlayerGui
local UIS=game:GetService("UserInputService")

local Theme=Color3.fromRGB(30,100,255)
local TColors={Color3.fromRGB(30,100,255),Color3.fromRGB(30,255,100),Color3.fromRGB(255,150,30),Color3.fromRGB(150,30,255)}
local Cases={"Daily","Trash","Beggar","Plodder","Office Clerk","Director","Oligarch","Manager","Frozen Heart","Bubble Gum","Cats","Dream","Glitch","Bloody Night","Ninja Turtles","Gold","Dark","Palm","Burj","Luxury","Monarch","Angel","M5 F90","G63","Porsche 911","URUS","Durov","Magnate","Cirque","REDO","Desk Calendars","Heavenfall","Abyss Core","Radioactive","Cursed Demon","Marina","Divine","Photon Core","Sunny day"}
