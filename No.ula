local G=Instance.new("ScreenGui",PG);G.Name="N6"
local M=Instance.new("Frame",G);M.Size=UDim2.new(0,180,0,260);M.Position=UDim2.new(0,50,0,100);M.BackgroundColor3=Color3.fromRGB(18,18,18);M.BorderSizePixel=0;M.ClipsDescendants=true
Instance.new("UICorner",M).CornerRadius=UDim.new(0,8)

local drag,ds,sp=false,nil,nil
local T=Instance.new("Frame",M);T.Size=UDim2.new(1,0,0,24);T.BackgroundColor3=Theme;T.BorderSizePixel=0
Instance.new("UICorner",T).CornerRadius=UDim.new(0,8)
local TL=Instance.new("TextLabel",T);TL.Text="NFT Battle v6";TL.Size=UDim2.new(1,-60,1,0);TL.Position=UDim2.new(0,8,0,0);TL.TextColor3=Color3.new(1,1,1);TL.Font=Enum.Font.GothamBold;TL.TextSize=10;TL.BackgroundTransparency=1;TL.TextXAlignment=Enum.TextXAlignment.Left
local CB=Instance.new("TextButton",T);CB.Text="×";CB.Size=UDim2.new(0,20,1,0);CB.Position=UDim2.new(1,-20,0,0);CB.TextColor3=Color3.new(1,1,1);CB.Font=Enum.Font.GothamBold;CB.TextSize=14;CB.BackgroundTransparency=1;CB.MouseButton1Click:Connect(function()G:Destroy()end)
local MB=Instance.new("TextButton",T);MB.Text="−";MB.Size=UDim2.new(0,20,1,0);MB.Position=UDim2.new(1,-40,0,0);MB.TextColor3=Color3.new(1,1,1);MB.Font=Enum.Font.GothamBold;MB.TextSize=14;MB.BackgroundTransparency=1
local min,OS=false,M.Size
MB.MouseButton1Click:Connect(function()min=not min;M.Size=min and UDim2.new(0,180,0,24)or OS;for _,v in ipairs(M:GetChildren())do if v~=T then v.Visible=not min end end end)

T.InputBegan:Connect(function(i)if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true;ds=i.Position;sp=M.Position end end)
UIS.InputChanged:Connect(function(i)if drag and i.UserInputType==Enum.UserInputType.Touch then local d=i.Position-ds;M.Position=UDim2.new(sp.X.Scale,sp.X.Offset+d.X,sp.Y.Scale,sp.Y.Offset+d.Y)end end)
UIS.InputEnded:Connect(function(i)if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end end)

local TF=Instance.new("Frame",M);TF.Size=UDim2.new(0,22,1,-24);TF.Position=UDim2.new(0,0,0,24);TF.BackgroundColor3=Color3.fromRGB(22,22,22);TF.BorderSizePixel=0
local PG2=Instance.new("Frame",M);PG2.Size=UDim2.new(1,-22,1,-24);PG2.Position=UDim2.new(0,22,0,24);PG2.BackgroundColor3=Color3.fromRGB(25,25,25);PG2.BorderSizePixel=0
local TB={"📦","⚔️","🔧","🎄","⚙️"}
local TP={}
for i,ic in ipairs(TB)do
 local b=Instance.new("TextButton",TF);b.Text=ic;b.Size=UDim2.new(1,0,0,28);b.Position=UDim2.new(0,0,0,(i-1)*28);b.BackgroundColor3=i==1 and Theme or Color3.fromRGB(30,30,30);b.TextColor3=Color3.new(1,1,1);b.Font=Enum.Font.Gotham;b.TextSize=10;b.BorderSizePixel=0
 local p=Instance.new("ScrollingFrame",PG2);p.Size=UDim2.new(1,-4,1,-4);p.Position=UDim2.new(0,2,0,2);p.BackgroundTransparency=1;p.Visible=i==1;p.CanvasSize=UDim2.new(0,0,0,0);p.ScrollBarThickness=2;TP[i]=p
 b.MouseButton1Click:Connect(function()for j,pp in ipairs(TP)do pp.Visible=j==i end;for _,bb in ipairs(TF:GetChildren())do if bb:IsA("TextButton")then bb.BackgroundColor3=Color3.fromRGB(30,30,30)end end;b.BackgroundColor3=Theme end)
end

local P1,P2,P3,P4,P5=TP[1],TP[2],TP[3],TP[4],TP[5]
