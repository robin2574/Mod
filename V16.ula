 local b=Instance.new("TextButton",P5);b.Text="🎁 "..cn;b.Size=UDim2.new(1,0,0,18);b.Position=UDim2.new(0,0,0,ny);b.BackgroundColor3=Color3.fromRGB(120,20,20);b.TextColor3=Color3.new(1,1,1);b.Font=Enum.Font.Gotham;b.TextSize=7;b.MouseButton1Click:Connect(function()Events.GUI:Fire("CasePage",cn)end)
