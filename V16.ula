local av=Instance.new("ImageLabel",P6);av.Size=UDim2.new(0,34,0,34);av.Position=UDim2.new(0,4,0,4);av.Image="https://www.roblox.com/headshot-thumbnail/image?userId="..Player.UserId.."&width=150&height=150&format=png";av.BackgroundColor3=Color3.fromRGB(30,30,30);Instance.new("UICorner",av).CornerRadius=UDim.new(1,0)
local cl3=Instance.new("TextLabel",P6);cl3.Text=Player.Name;cl3.Size=UDim2.new(1,-42,0,15);cl3.Position=UDim2.new(0,42,0,5);cl3.TextColor3=Color3.new(1,1,1);cl3.Font=Enum.Font.GothamBold;cl3.TextSize=8;cl3.BackgroundTransparency=1;cl3.TextXAlignment=Enum.TextXAlignment.Left
