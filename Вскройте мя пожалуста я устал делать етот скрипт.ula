-- Создание вкладок NFT
for i, tab in ipairs(NftTabs) do
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 38, 0, 30)
    btn.Position = UDim2.new(0, (i-1)*40, 0, 3)
    btn.BackgroundColor3 = i == 1 and Color3.fromRGB(50, 100, 200) or Color3.fromRGB(35, 35, 50)
    btn.Text = tab
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextSize = 12
    btn.Font = Enum.Font.Gotham
    btn.Parent = NftTabFrame
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    
    local content = Instance.new("Frame")
    content.Size = UDim2.new(1, 0, 1, 0)
    content.BackgroundTransparency = 1
    content.Visible = i == 1
    content.Parent = NftContentFrame
    table.insert(NftTabContent, content)
    
    btn.MouseButton1Click:Connect(function()
        for _, b in ipairs(NftTabFrame:GetChildren()) do
            if b:IsA("TextButton") then b.BackgroundColor3 = Color3.fromRGB(35, 35, 50) end
        end
        btn.BackgroundColor3 = Color3.fromRGB(50, 100, 200)
        for _, c in ipairs(NftTabContent) do c.Visible = false end
        content.Visible = true
    end)
end

