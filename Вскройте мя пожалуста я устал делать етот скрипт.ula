-- Вкладки Ton Battle
local TonTabs = {"💰", "🖼️", "⚔️", "🎰"}
local TonTabNames = {"Валюта", "NFT", "Батл", "Рулетка"}
local TonTabFrame = Instance.new("Frame")
TonTabFrame.Size = UDim2.new(1, -20, 0, 35)
TonTabFrame.Position = UDim2.new(0, 10, 0, 95)
TonTabFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
TonTabFrame.BorderSizePixel = 0
TonTabFrame.Parent = TonMenu

local TonTabContent = {}
local TonContentFrame = Instance.new("Frame")
TonContentFrame.Size = UDim2.new(1, -20, 0, 280)
TonContentFrame.Position = UDim2.new(0, 10, 0, 140)
TonContentFrame.BackgroundColor3 = Color3.fromRGB(18, 18, 28)
TonContentFrame.BorderSizePixel = 0
TonContentFrame.Parent = TonMenu
Instance.new("UICorner", TonContentFrame).CornerRadius = UDim.new(0, 8)

-- Создание вкладок Ton
for i, tab in ipairs(TonTabs) do
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 70, 0, 30)
    btn.Position = UDim2.new(0, (i-1)*75, 0, 3)
    btn.BackgroundColor3 = i == 1 and Color3.fromRGB(50, 100, 200) or Color3.fromRGB(35, 35, 50)
    btn.Text = tab
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextSize = 14
    btn.Font = Enum.Font.Gotham
    btn.Parent = TonTabFrame
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    
    local content = Instance.new("Frame")
    content.Size = UDim2.new(1, 0, 1, 0)
    content.BackgroundTransparency = 1
    content.Visible = i == 1
    content.Parent = TonContentFrame
    table.insert(TonTabContent, content)
    
    btn.MouseButton1Click:Connect(function()
        for _, b in ipairs(TonTabFrame:GetChildren()) do
            if b:IsA("TextButton") then b.BackgroundColor3 = Color3.fromRGB(35, 35, 50) end
        end
        btn.BackgroundColor3 = Color3.fromRGB(50, 100, 200)
        for _, c in ipairs(TonTabContent) do c.Visible = false end
        content.Visible = true
    end)
end

-- Контент Ton Battle
-- ВАЛЮТА
local tonScroll = Instance.new("ScrollingFrame")
tonScroll.Size = UDim2.new(1, -10, 1, -10)
tonScroll.Position = UDim2.new(0, 5, 0, 5)
tonScroll.BackgroundTransparency = 1
tonScroll.BorderSizePixel = 0
tonScroll.ScrollBarThickness = 3
tonScroll.CanvasSize = UDim2.new(0, 0, 0, 120)
tonScroll.Parent = TonTabContent[1]

local y = 0
for _, curr in ipairs({"_TONValue", "_GemsValue"}) do
    local val = Player:FindFirstChild(curr)
    if val then
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(0, 80, 0, 25)
        label.Position = UDim2.new(0, 5, 0, y)
        label.BackgroundTransparency = 1
        label.Text = (curr == "_TONValue" and "💎 TON" or "💠 Gems") .. ":"
        label.TextColor3 = Color3.fromRGB(200, 200, 200)
        label.TextSize = 12
        label.Font = Enum.Font.Gotham
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.Parent = tonScroll
        
        local input = Instance.new("TextBox")
        input.Size = UDim2.new(0, 150, 0, 25)
        input.Position = UDim2.new(0, 90, 0, y)
        input.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
        input.Text = tostring(val.Value)
        input.TextColor3 = Color3.fromRGB(255, 255, 255)
        input.TextSize = 12
        input.Font = Enum.Font.Gotham
        input.Parent = tonScroll
        Instance.new("UICorner", input).CornerRadius = UDim.new(0, 4)
        
        local setBtn = Instance.new("TextButton")
        setBtn.Size = UDim2.new(0, 40, 0, 25)
        setBtn.Position = UDim2.new(0, 245, 0, y)
        setBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
        setBtn.Text = "✓"
        setBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        setBtn.TextSize = 14
        setBtn.Font = Enum.Font.GothamBold
        setBtn.Parent = tonScroll
        Instance.new("UICorner", setBtn).CornerRadius = UDim.new(0, 4)
        
        setBtn.MouseButton1Click:Connect(function()
            local newVal = tonumber(input.Text)
            if newVal then
                val.Value = newVal
                input.Text = tostring(val.Value)
            end
        end)
        
        y = y + 35
    end
end

