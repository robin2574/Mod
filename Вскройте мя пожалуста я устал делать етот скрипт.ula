    b.TextSize = 13
    b.Font = Enum.Font.GothamBold
    b.Parent = shopScroll
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)
    b.MouseButton1Click:Connect(btn[3])
    y = y + 48
end

-- БАТЛ ПАСС
local bpScroll = Instance.new("ScrollingFrame")
bpScroll.Size = UDim2.new(1, -10, 1, -10)
bpScroll.Position = UDim2.new(0, 5, 0, 5)
bpScroll.BackgroundTransparency = 1
bpScroll.BorderSizePixel = 0
bpScroll.ScrollBarThickness = 3
bpScroll.CanvasSize = UDim2.new(0, 0, 0, 250)
bpScroll.Parent = NftTabContent[4]

y = 0
local bpLevel = Player:FindFirstChild("_BPLevel")
if bpLevel then
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 80, 0, 25)
    label.Position = UDim2.new(0, 5, 0, y)
    label.BackgroundTransparency = 1
    label.Text = "Уровень:"
    label.TextColor3 = Color3.fromRGB(200, 200, 200)
    label.TextSize = 12
    label.Font = Enum.Font.Gotham
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = bpScroll
    
    local input = Instance.new("TextBox")
    input.Size = UDim2.new(0, 100, 0, 25)
    input.Position = UDim2.new(0, 90, 0, y)
    input.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    input.Text = tostring(bpLevel.Value)
    input.TextColor3 = Color3.fromRGB(255, 255, 255)
    input.TextSize = 12
    input.Font = Enum.Font.Gotham
    input.Parent = bpScroll
    Instance.new("UICorner", input).CornerRadius = UDim.new(0, 4)
    
    local setBtn = Instance.new("TextButton")
    setBtn.Size = UDim2.new(0, 40, 0, 25)
    setBtn.Position = UDim2.new(0, 195, 0, y)
    setBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
    setBtn.Text = "✓"
    setBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    setBtn.TextSize = 14
    setBtn.Font = Enum.Font.GothamBold
    setBtn.Parent = bpScroll
    Instance.new("UICorner", setBtn).CornerRadius = UDim.new(0, 4)
    
    setBtn.MouseButton1Click:Connect(function()
        local val = tonumber(input.Text)
        if val then
            bpLevel.Value = math.clamp(val, 1, 50)
            input.Text = tostring(bpLevel.Value)
        end
    end)
    
    y = y + 35
end

