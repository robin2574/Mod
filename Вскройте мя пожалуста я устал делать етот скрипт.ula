nftRouletteBtn.MouseButton1Click:Connect(function()
    local PlayerGui = Player:WaitForChild("PlayerGui")
    local MainGui = PlayerGui:FindFirstChild("MainGui")
    if MainGui then
        local Pages = MainGui:FindFirstChild("Pages")
        if Pages then
            local fusePage = Pages:FindFirstChild("Fuse")
            local craftPage = Pages:FindFirstChild("Crafts")
            if fusePage then fusePage.Visible = true
            elseif craftPage then craftPage.Visible = true end
            MainGui.Visible = true
        end
    end
end)

