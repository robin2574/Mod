        label.Text = (curr == "_StarsValue" and "⭐ Stars" or curr == "_TONValue" and "💎 TON" or curr == "_GemsValue" and "💠 Gems" or "❄️ Snow") .. ":"
        label.TextColor3 = Color3.fromRGB(200, 200, 200)
        label.TextSize = 11
        label.Font = Enum.Font.Gotham
