-- Обновление баланса
task.spawn(function()
    while true do
        local ton = Player:FindFirstChild("_TONValue")
        local gems = Player:FindFirstChild("_GemsValue")
        local stars = Player:FindFirstChild("_StarsValue")
        local snow = Player:FindFirstChild("_SnowflakesValue")
        
        if TonBalance then
            TonBalance.Text = "💎 " .. (ton and ton.Value or 0) .. "  💠 " .. (gems and gems.Value or 0)
        end
        if NftBalance then
            NftBalance.Text = "⭐ " .. (stars and stars.Value or 0) .. "  💎 " .. (ton and ton.Value or 0) .. "  💠 " .. (gems and gems.Value or 0) .. "  ❄️ " .. (snow and snow.Value or 0)
        end
        task.wait(1)
    end
end)

