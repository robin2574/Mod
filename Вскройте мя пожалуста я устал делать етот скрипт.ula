y = y + 45

local inv = Player:FindFirstChild("_Inventory")
if inv then
    for _, item in ipairs(inv:GetChildren()) do
        local hidden = item:GetAttribute("Hidden")
        local itemBtn = Instance.new("TextButton")
        itemBtn.Size = UDim2.new(1, -10, 0, 28)
        itemBtn.Position = UDim2.new(0, 5, 0, y)
        itemBtn.BackgroundColor3 = hidden and Color3.fromRGB(150, 50, 50) or Color3.fromRGB(40, 40, 50)
        itemBtn.Text = item.Name .. (hidden and " (Скрыто)" or "")
        itemBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        itemBtn.TextSize = 10
        itemBtn.Font = Enum.Font.Gotham
        itemBtn.Parent = hideScroll
        Instance.new("UICorner", itemBtn).CornerRadius = UDim.new(0, 4)
        
        itemBtn.MouseButton1Click:Connect(function()
            local newState = not item:GetAttribute("Hidden")
            item:SetAttribute("Hidden", newState or nil)
            itemBtn.BackgroundColor3 = newState and Color3.fromRGB(150, 50, 50) or Color3.fromRGB(40, 40, 50)
            itemBtn.Text = item.Name .. (newState and " (Скрыто)" or "")
        end)
        
        y = y + 33
    end
end

hideScroll.CanvasSize = UDim2.new(0, 0, 0, y + 10)

