        setBtn.Parent = nftValScroll
        Instance.new("UICorner", setBtn).CornerRadius = UDim.new(0, 4)
        
        setBtn.MouseButton1Click:Connect(function()
            local newVal = tonumber(input.Text)
            if newVal then
                val.Value = newVal
                input.Text = tostring(val.Value)
            end
        end)
        
        y = y + 35
    end
end

-- NFT (BestDrop, добавить, индекс)
local nftNftScroll = Instance.new("ScrollingFrame")
nftNftScroll.Size = UDim2.new(1, -10, 1, -10)
nftNftScroll.Position = UDim2.new(0, 5, 0, 5)
nftNftScroll.BackgroundTransparency = 1
nftNftScroll.BorderSizePixel = 0
nftNftScroll.ScrollBarThickness = 3
nftNftScroll.CanvasSize = UDim2.new(0, 0, 0, 250)
nftNftScroll.Parent = NftTabContent[2]

y = 0
local bestDrop2 = Player:FindFirstChild("_BestDrop")
if bestDrop2 then
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 100, 0, 25)
    label.Position = UDim2.new(0, 5, 0, y)
    label.BackgroundTransparency = 1
    label.Text = "Лучший дроп:"
    label.TextColor3 = Color3.fromRGB(200, 200, 200)
    label.TextSize = 12
    label.Font = Enum.Font.Gotham
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = nftNftScroll
    
    local input = Instance.new("TextBox")
    input.Size = UDim2.new(0, 180, 0, 25)
    input.Position = UDim2.new(0, 5, 0, y+25)
    input.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    input.Text = bestDrop2.Value
    input.TextColor3 = Color3.fromRGB(255, 255, 255)
    input.TextSize = 11
    input.Font = Enum.Font.Gotham
    input.Parent = nftNftScroll
    Instance.new("UICorner", input).CornerRadius = UDim.new(0, 4)
    
    local setBtn = Instance.new("TextButton")
    setBtn.Size = UDim2.new(0, 60, 0, 25)
    setBtn.Position = UDim2.new(0, 190, 0, y+25)
    setBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
    setBtn.Text = "Уст."
    setBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    setBtn.TextSize = 12
    setBtn.Font = Enum.Font.GothamBold
    setBtn.Parent = nftNftScroll
    Instance.new("UICorner", setBtn).CornerRadius = UDim.new(0, 4)
    
    setBtn.MouseButton1Click:Connect(function()
        bestDrop2.Value = input.Text
    end)
    
    y = y + 60
end

