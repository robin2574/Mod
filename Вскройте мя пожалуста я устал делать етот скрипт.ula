showAllBtn.Size = UDim2.new(1, -10, 0, 35)
showAllBtn.Position = UDim2.new(0, 5, 0, y)
showAllBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
showAllBtn.Text = "👁️ Показать всё"
showAllBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
