local v4, s4 = CreateContent("Батл Пасс")
yPos = 0

local bpLevel = Player:FindFirstChild("_BPLevel")
local bpXP = Player:FindFirstChild("_BPXP")
local bpPrem = Player:FindFirstChild("_BPPremium")

if bpLevel then
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 80, 0, 25)
    label.Position = UDim2.new(0, 5, 0, yPos)
    label.BackgroundTransparency = 1
    label.Text = "Уровень:"
    label.TextColor3 = Color3.fromRGB(200, 200, 200)
    label.TextSize = 12
    label.Font = Enum.Font.Gotham
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = s4
    
    local input = Instance.new("TextBox")
    input.Size = UDim2.new(0, 100, 0, 25)
    input.Position = UDim2.new(0, 90, 0, yPos)
    input.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    input.Text = tostring(bpLevel.Value)
    input.TextColor3 = Color3.fromRGB(255, 255, 255)
    input.TextSize = 12
    input.Font = Enum.Font.Gotham
    input.Parent = s4
    Instance.new("UICorner", input).CornerRadius = UDim.new(0, 4)
    
    local setBtn = Instance.new("TextButton")
    setBtn.Size = UDim2.new(0, 40, 0, 25)
    setBtn.Position = UDim2.new(0, 195, 0, yPos)
    setBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
    setBtn.Text = "✓"
    setBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    setBtn.TextSize = 14
    setBtn.Font = Enum.Font.GothamBold
    setBtn.Parent = s4
    Instance.new("UICorner", setBtn).CornerRadius = UDim.new(0, 4)
    
    setBtn.MouseButton1Click:Connect(function()
        local val = tonumber(input.Text)
        if val then
            bpLevel.Value = math.clamp(val, 1, 50)
            input.Text = tostring(bpLevel.Value)
        end
    end)
    
    yPos = yPos + 35
end

if bpXP then
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 80, 0, 25)
    label.Position = UDim2.new(0, 5, 0, yPos)
    label.BackgroundTransparency = 1
    label.Text = "XP:"
