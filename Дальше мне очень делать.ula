    local idx = Player:FindFirstChild("_Index")
    if idx and idxNameInput.Text ~= "" then
        local item = idx:FindFirstChild(idxNameInput.Text)
        if not item then
            item = Instance.new("IntValue")
            item.Name = idxNameInput.Text
            item.Parent = idx
        end
        local val = tonumber(idxValueInput.Text) or 1
        item.Value = val
    end
end)

