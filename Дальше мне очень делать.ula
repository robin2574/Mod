--[[
    NFT/TON BATTLE MOBILE HUB v2.0
    Компактный GUI для телефона
    Два режима: NFT Battle и Ton Battle
--]]

local Player = game:GetService("Players").LocalPlayer
local RS = game:GetService("ReplicatedStorage")
local CoreGui = game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")

-- Очистка старого GUI
if CoreGui:FindFirstChild("MobileHub") then
    CoreGui.MobileHub:Destroy()
end

local Hub = Instance.new("ScreenGui")
Hub.Name = "MobileHub"
Hub.Parent = CoreGui
Hub.ResetOnSpawn = false
Hub.IgnoreGuiInset = true

-- Главный фрейм (компактный под телефон)
local MainFrame = Instance.new("Frame")
MainFrame.Size = UDim2.new(0, 350, 0, 500)
MainFrame.Position = UDim2.new(0.5, -175, 0.5, -250)
MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 25)
MainFrame.BorderSizePixel = 0
MainFrame.Active = true
MainFrame.Draggable = true
MainFrame.Visible = true
MainFrame.Parent = Hub

-- Закругление углов
local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(0, 12)
UICorner.Parent = MainFrame

-- Верхняя панель
local TopBar = Instance.new("Frame")
TopBar.Size = UDim2.new(1, 0, 0, 50)
TopBar.BackgroundColor3 = Color3.fromRGB(25, 25, 40)
TopBar.BorderSizePixel = 0
TopBar.Parent = MainFrame
Instance.new("UICorner", TopBar).CornerRadius = UDim.new(0, 12)

local Title = Instance.new("TextLabel")
