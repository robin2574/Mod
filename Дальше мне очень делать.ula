createBattleBtn.MouseButton1Click:Connect(function()
    local caseName = caseInput.Text
    local count = tonumber(countInput.Text) or 1
    count = math.clamp(count, 1, 10)
    
    local cases = {}
    for i = 1, count do
        table.insert(cases, caseName)
    end
    
    local Battles = RS.Events.Battles
    if Battles then
        Battles:InvokeServer("Create", cases, {})
    end
end)

