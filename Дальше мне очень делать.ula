debugBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
debugBtn.TextSize = 13
debugBtn.Font = Enum.Font.GothamBold
debugBtn.Parent = s8
Instance.new("UICorner", debugBtn).CornerRadius = UDim.new(0, 6)

debugBtn.MouseButton1Click:Connect(function()
    debugToggle = not debugToggle
    debugBtn.BackgroundColor3 = debugToggle and Color3.fromRGB(50, 200, 50) or Color3.fromRGB(50, 50, 50)
    debugBtn.Text = debugToggle and "🐛 Debug Mode: ВКЛ" or "🐛 Debug Mode: ВЫКЛ"
end)

yPos = yPos + 45

local fuseBtn = Instance.new("TextButton")
fuseBtn.Size = UDim2.new(1, -10, 0, 50)
fuseBtn.Position = UDim2.new(0, 5, 0, yPos)
fuseBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 150)
fuseBtn.Text = "🔥 ЗАПУСТИТЬ ФЬЮЗ"
fuseBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
fuseBtn.TextSize = 14
fuseBtn.Font = Enum.Font.GothamBold
fuseBtn.Parent = s8
Instance.new("UICorner", fuseBtn).CornerRadius = UDim.new(0, 8)

fuseBtn.MouseButton1Click:Connect(function()
    local inv = Player:FindFirstChild("_Inventory")
    if inv then
        local items = {}
        for _, item in ipairs(inv:GetChildren()) do
            if #items < 5 and not item:GetAttribute("Unique") then
                table.insert(items, item)
            end
        end
        if #items == 5 then
            local Fuse = RS.Events.Fuse
            if Fuse then
                Fuse:InvokeServer("Fuse", items, debugToggle)
            end
        end
    end
end)

