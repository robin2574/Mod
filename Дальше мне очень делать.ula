    premBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    premBtn.TextSize = 13
    premBtn.Font = Enum.Font.GothamBold
    premBtn.Parent = s4
    Instance.new("UICorner", premBtn).CornerRadius = UDim.new(0, 6)
    
