HideButton.Font = Enum.Font.GothamBold
HideButton.Parent = TopBar
Instance.new("UICorner", HideButton).CornerRadius = UDim.new(0, 6)

local VisibleToggle = true
HideButton.MouseButton1Click:Connect(function()
    VisibleToggle = not VisibleToggle
    MainFrame.Visible = VisibleToggle
    HideButton.Text = VisibleToggle and "Скрыть" or "Показать"
end)

-- Баланс
local BalanceFrame = Instance.new("Frame")
BalanceFrame.Size = UDim2.new(1, -20, 0, 35)
BalanceFrame.Position = UDim2.new(0, 10, 0, 60)
BalanceFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
BalanceFrame.BorderSizePixel = 0
BalanceFrame.Parent = MainFrame

local function UpdateBalances()
    local stars = Player:FindFirstChild("_StarsValue")
    local ton = Player:FindFirstChild("_TONValue")
    local gems = Player:FindFirstChild("_GemsValue")
    local snow = Player:FindFirstChild("_SnowflakesValue")
    
    local balanceText = ""
    if stars then balanceText = balanceText .. "⭐ " .. stars.Value .. "  " end
    if ton then balanceText = balanceText .. "💎 " .. ton.Value .. "  " end
    if gems then balanceText = balanceText .. "💠 " .. gems.Value .. "  " end
    if snow then balanceText = balanceText .. "❄️ " .. snow.Value end
    
    BalanceLabel.Text = balanceText
end

local BalanceLabel = Instance.new("TextLabel")
BalanceLabel.Size = UDim2.new(1, 0, 1, 0)
BalanceLabel.BackgroundTransparency = 1
BalanceLabel.Text = "⭐ 0  💎 0  💠 0  ❄️ 0"
BalanceLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
BalanceLabel.TextSize = 12
BalanceLabel.Font = Enum.Font.Gotham
BalanceLabel.Parent = BalanceFrame

UpdateBalances()

-- Выбор режима
local ModeFrame = Instance.new("Frame")
ModeFrame.Size = UDim2.new(1, -20, 0, 35)
ModeFrame.Position = UDim2.new(0, 10, 0, 105)
ModeFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
ModeFrame.BorderSizePixel = 0
ModeFrame.Parent = MainFrame

local ModeLabel = Instance.new("TextLabel")
ModeLabel.Size = UDim2.new(0, 80, 1, 0)
ModeLabel.Position = UDim2.new(0, 5, 0, 0)
ModeLabel.BackgroundTransparency = 1
ModeLabel.Text = "Режим:"
ModeLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
ModeLabel.TextSize = 12
ModeLabel.Font = Enum.Font.Gotham
ModeLabel.TextXAlignment = Enum.TextXAlignment.Left
ModeLabel.Parent = ModeFrame

local ModeDropdown = Instance.new("TextButton")
ModeDropdown.Size = UDim2.new(0, 150, 0, 28)
ModeDropdown.Position = UDim2.new(0, 90, 0, 3)
ModeDropdown.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
ModeDropdown.Text = "🎮 NFT Battle"
ModeDropdown.TextColor3 = Color3.fromRGB(255, 255, 255)
ModeDropdown.TextSize = 12
ModeDropdown.Font = Enum.Font.Gotham
ModeDropdown.Parent = ModeFrame
Instance.new("UICorner", ModeDropdown).CornerRadius = UDim.new(0, 6)

local Modes = {"🎮 NFT Battle", "💎 Ton Battle"}
local CurrentMode = 1

ModeDropdown.MouseButton1Click:Connect(function()
    CurrentMode = CurrentMode == 1 and 2 or 1
    ModeDropdown.Text = Modes[CurrentMode]
    
    -- Показать/скрыть вкладки в зависимости от режима
    for _, tab in ipairs(TabButtons:GetChildren()) do
        if tab:IsA("TextButton") then
            local tabName = tab.Text
            if CurrentMode == 2 then -- Ton Battle
                if tabName == "💎 TON" or tabName == "🖼️ NFT" or tabName == "⚔️ Батл" or tabName == "🎰 Рулетка" then
                    tab.Visible = true
                else
                    tab.Visible = false
                end
            else -- NFT Battle
                tab.Visible = true
            end
        end
    end
end)

-- Вкладки
local TabFrame = Instance.new("Frame")
TabFrame.Size = UDim2.new(1, -20, 0, 35)
TabFrame.Position = UDim2.new(0, 10, 0, 150)
TabFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
TabFrame.BorderSizePixel = 0
TabFrame.Parent = MainFrame

local TabButtons = Instance.new("ScrollingFrame")
TabButtons.Size = UDim2.new(1, 0, 1, 0)
TabButtons.BackgroundTransparency = 1
TabButtons.BorderSizePixel = 0
TabButtons.ScrollBarThickness = 2
TabButtons.CanvasSize = UDim2.new(0, 600, 0, 0)
TabButtons.Parent = TabFrame

local Tabs = {"💰", "🖼️", "🛒", "📋", "👻", "🎰", "⚔️", "🔥"}
local TabNames = {"Валюта", "NFT", "Шоп", "БП", "Скрыть", "Рулетка", "Батл", "Фьюз"}
local CurrentTab = 1
local TabContent = {}

for i, tab in ipairs(Tabs) do
    local TabButton = Instance.new("TextButton")
    TabButton.Size = UDim2.new(0, 60, 0, 30)
    TabButton.Position = UDim2.new(0, (i-1)*65, 0, 3)
    TabButton.BackgroundColor3 = i == 1 and Color3.fromRGB(50, 100, 200) or Color3.fromRGB(35, 35, 50)
    TabButton.Text = tab
    TabButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    TabButton.TextSize = 14
    TabButton.Font = Enum.Font.Gotham
    TabButton.Parent = TabButtons
    Instance.new("UICorner", TabButton).CornerRadius = UDim.new(0, 6)
    
    TabButton.MouseButton1Click:Connect(function()
        for _, btn in ipairs(TabButtons:GetChildren()) do
            if btn:IsA("TextButton") then
                btn.BackgroundColor3 = Color3.fromRGB(35, 35, 50)
            end
        end
        TabButton.BackgroundColor3 = Color3.fromRGB(50, 100, 200)
        
        for _, content in ipairs(TabContent) do
            content.Visible = false
        end
        if TabContent[i] then
            TabContent[i].Visible = true
        end
    end)
end

-- Контент вкладок
local ContentFrame = Instance.new("Frame")
ContentFrame.Size = UDim2.new(1, -20, 0, 240)
ContentFrame.Position = UDim2.new(0, 10, 0, 195)
ContentFrame.BackgroundColor3 = Color3.fromRGB(18, 18, 28)
ContentFrame.BorderSizePixel = 0
ContentFrame.Parent = MainFrame
Instance.new("UICorner", ContentFrame).CornerRadius = UDim.new(0, 8)

-- Создание контента для каждой вкладки
local function CreateContent(title)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundTransparency = 1
    frame.Visible = false
    frame.Parent = ContentFrame
    
    local scroll = Instance.new("ScrollingFrame")
    scroll.Size = UDim2.new(1, -10, 1, -10)
    scroll.Position = UDim2.new(0, 5, 0, 5)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel = 0
    scroll.ScrollBarThickness = 3
    scroll.CanvasSize = UDim2.new(0, 0, 0, 400)
    scroll.Parent = frame
    
    return frame, scroll
end

-- ВКЛАДКА 1: ВАЛЮТА
local v1, s1 = CreateContent("Валюта")
local yPos = 0

local currencies = {
    {Name = "_StarsValue", Label = "⭐ Stars", Min = 0, Max = 1000000000},
    {Name = "_TONValue", Label = "💎 TON", Min = 0, Max = 1000000},
    {Name = "_GemsValue", Label = "💠 Gems", Min = 0, Max = 100000},
    {Name = "_SnowflakesValue", Label = "❄️ Snowflakes", Min = 0, Max = 100000}
}

for _, curr in ipairs(currencies) do
    local val = Player:FindFirstChild(curr.Name)
    if val then
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(0, 120, 0, 25)
        label.Position = UDim2.new(0, 5, 0, yPos)
        label.BackgroundTransparency = 1
        label.Text = curr.Label .. ":"
        label.TextColor3 = Color3.fromRGB(200, 200, 200)
        label.TextSize = 12
        label.Font = Enum.Font.Gotham
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.Parent = s1
        
        local input = Instance.new("TextBox")
        input.Size = UDim2.new(0, 150, 0, 25)
        input.Position = UDim2.new(0, 130, 0, yPos)
        input.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
        input.Text = tostring(val.Value)
        input.TextColor3 = Color3.fromRGB(255, 255, 255)
        input.TextSize = 12
        input.Font = Enum.Font.Gotham
        input.Parent = s1
        Instance.new("UICorner", input).CornerRadius = UDim.new(0, 4)
        
        local setBtn = Instance.new("TextButton")
        setBtn.Size = UDim2.new(0, 40, 0, 25)
        setBtn.Position = UDim2.new(0, 285, 0, yPos)
        setBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
        setBtn.Text = "✓"
        setBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        setBtn.TextSize = 14
        setBtn.Font = Enum.Font.GothamBold
        setBtn.Parent = s1
        Instance.new("UICorner", setBtn).CornerRadius = UDim.new(0, 4)
        
        setBtn.MouseButton1Click:Connect(function()
            local newVal = tonumber(input.Text)
            if newVal then
                val.Value = math.clamp(newVal, curr.Min, curr.Max)
                input.Text = tostring(val.Value)
                UpdateBalances()
            end
        end)
        
        yPos = yPos + 35
    end
end

s1.CanvasSize = UDim2.new(0, 0, 0, yPos + 10)
table.insert(TabContent, v1)

