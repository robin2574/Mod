-- ВКЛАДКА 5: СКРЫТЬ NFT
local v5, s5 = CreateContent("Скрыть NFT")
yPos = 0

local showAllBtn = Instance.new("TextButton")
showAllBtn.Size = UDim2.new(1, -10, 0, 35)
showAllBtn.Position = UDim2.new(0, 5, 0, yPos)
showAllBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
showAllBtn.Text = "👁️ Показать всё"
showAllBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
showAllBtn.TextSize = 13
showAllBtn.Font = Enum.Font.GothamBold
showAllBtn.Parent = s5
Instance.new("UICorner", showAllBtn).CornerRadius = UDim.new(0, 6)

showAllBtn.MouseButton1Click:Connect(function()
    local inv = Player:FindFirstChild("_Inventory")
    if inv then
        for _, item in ipairs(inv:GetChildren()) do
            item:SetAttribute("Hidden", nil)
        end
    end
    -- Перезагрузить список
    for _, btn in ipairs(s5:GetChildren()) do
        if btn:IsA("TextButton") and btn.Name == "HideItem" then
            btn:Destroy()
        end
    end
end)

yPos = yPos + 45

local inv = Player:FindFirstChild("_Inventory")
if inv then
    for _, item in ipairs(inv:GetChildren()) do
        local hidden = item:GetAttribute("Hidden")
        
        local itemFrame = Instance.new("TextButton")
        itemFrame.Name = "HideItem"
        itemFrame.Size = UDim2.new(1, -10, 0, 30)
        itemFrame.Position = UDim2.new(0, 5, 0, yPos)
        itemFrame.BackgroundColor3 = hidden and Color3.fromRGB(150, 50, 50) or Color3.fromRGB(40, 40, 50)
        itemFrame.Text = item.Name .. (hidden and " (Скрыто)" or "")
        itemFrame.TextColor3 = Color3.fromRGB(255, 255, 255)
        itemFrame.TextSize = 10
        itemFrame.Font = Enum.Font.Gotham
        itemFrame.Parent = s5
        Instance.new("UICorner", itemFrame).CornerRadius = UDim.new(0, 4)
        
        itemFrame.MouseButton1Click:Connect(function()
            local newState = not item:GetAttribute("Hidden")
            item:SetAttribute("Hidden", newState or nil)
            itemFrame.BackgroundColor3 = newState and Color3.fromRGB(150, 50, 50) or Color3.fromRGB(40, 40, 50)
            itemFrame.Text = item.Name .. (newState and " (Скрыто)" or "")
        end)
        
        yPos = yPos + 35
    end
end

s5.CanvasSize = UDim2.new(0, 0, 0, yPos + 10)
table.insert(TabContent, v5)

-- ВКЛАДКА 6: РУЛЕТКА
local v6, s6 = CreateContent("Рулетка")
yPos = 0

local rouletteBtn = Instance.new("TextButton")
rouletteBtn.Size = UDim2.new(1, -10, 0, 50)
rouletteBtn.Position = UDim2.new(0, 5, 0, yPos)
rouletteBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
rouletteBtn.Text = "🎰 ОТКРЫТЬ РУЛЕТКУ"
rouletteBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
rouletteBtn.TextSize = 16
rouletteBtn.Font = Enum.Font.GothamBold
rouletteBtn.Parent = s6
Instance.new("UICorner", rouletteBtn).CornerRadius = UDim.new(0, 8)

rouletteBtn.MouseButton1Click:Connect(function()
    -- Открывает новогоднюю рулетку (Fuse/Craft)
    local PlayerGui = Player:WaitForChild("PlayerGui")
    local MainGui = PlayerGui:FindFirstChild("MainGui")
    if MainGui then
        local Pages = MainGui:FindFirstChild("Pages")
        if Pages then
            -- Пытаемся открыть Fuse или Craft
            local fusePage = Pages:FindFirstChild("Fuse")
            local craftPage = Pages:FindFirstChild("Crafts")
            if fusePage then
                fusePage.Visible = true
            elseif craftPage then
                craftPage.Visible = true
            end
            MainGui.Visible = true
        end
    end
end)

