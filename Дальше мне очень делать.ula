yPos = 0

local debugToggle = false
local selectedItems = {}

local debugBtn = Instance.new("TextButton")
debugBtn.Size = UDim2.new(1, -10, 0, 35)
debugBtn.Position = UDim2.new(0, 5, 0, yPos)
debugBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
