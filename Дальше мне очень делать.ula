-- ВКЛАДКА 3: ШОП
local v3, s3 = CreateContent("Шоп")
yPos = 0

local shopButtons = {
    {Text = "🍀 Запустить удачу", Color = Color3.fromRGB(50, 150, 50), Action = function()
        local LuckValue = RS:FindFirstChild("LuckValue")
        local LuckValue2 = RS:FindFirstChild("LuckValue2")
        local CrossValue = RS:FindFirstChild("CrossValue")
        if LuckValue then LuckValue.Value = 99999 end
        if LuckValue2 then LuckValue2.Value = 99999 end
        if CrossValue then CrossValue.Value = 99999 end
        local lp1 = Player:FindFirstChild("_LuckyPotion")
        local lp2 = Player:FindFirstChild("_LuckyPotion2")
        if lp1 then lp1.Value = 99999 end
        if lp2 then lp2.Value = 99999 end
    end},
    {Text = "⚡ Fast Upgrade", Color = Color3.fromRGB(200, 150, 50), Action = function()
        local pass = Player:FindFirstChild("_1628441770") or Instance.new("NumberValue", Player)
        pass.Name = "_1628441770"
        pass.Value = 1
    end},
    {Text = "📦 Auto Open", Color = Color3.fromRGB(50, 100, 200), Action = function()
        local pass = Player:FindFirstChild("_1651738174") or Instance.new("NumberValue", Player)
        pass.Name = "_1651738174"
        pass.Value = 1
    end},
    {Text = "👑 Premium BP", Color = Color3.fromRGB(200, 100, 200), Action = function()
        local pass = Player:FindFirstChild("_1640776898") or Instance.new("NumberValue", Player)
        pass.Name = "_1640776898"
        pass.Value = 1
        local prem = Player:FindFirstChild("_BPPremium")
        if prem then prem.Value = 1 end
    end}
}

for _, btn in ipairs(shopButtons) do
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1, -10, 0, 35)
    b.Position = UDim2.new(0, 5, 0, yPos)
    b.BackgroundColor3 = btn.Color
    b.Text = btn.Text
    b.TextColor3 = Color3.fromRGB(255, 255, 255)
    b.TextSize = 13
    b.Font = Enum.Font.GothamBold
    b.Parent = s3
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)
    
    b.MouseButton1Click:Connect(btn.Action)
    
    yPos = yPos + 45
end

s3.CanvasSize = UDim2.new(0, 0, 0, yPos + 10)
table.insert(TabContent, v3)

